# LLM 提供商（任选其一，优先 DeepSeek 成本最低）
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM 模型配置
LLM_PROVIDER=deepseek              # deepseek | openai | anthropic
LLM_MODEL=deepseek-chat

# 数据源 API Keys
GITHUB_TOKEN=                       # GitHub API（抓取 trending 选用）
PRODUCT_HUNT_TOKEN=                 # https://api.producthunt.com/v2/oauth/applications
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=dailydawn/0.1

# Web 层 Webhook（生成完通知 Web 层发邮件）
WEB_WEBHOOK_URL=
WEB_WEBHOOK_SECRET=
