# LLM（OpenAI 兼容协议，支持 OpenAI / DeepSeek / Doubao / OneAPI 中转等）
# 三者均为必需，无默认值
LLM_API_KEY=
LLM_BASE_URL=                       # OpenAI 兼容协议的 Chat Completions endpoint
LLM_MODEL=                          # 模型名，如 gpt-4o-mini / deepseek-chat 等

# 数据源 API Keys（全部可选；缺失则对应 fetcher 跳过）
PRODUCT_HUNT_TOKEN=                 # https://api.producthunt.com/v2/oauth/applications
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=dailydawn/0.1

# Web 层 Webhook（生成完通知 Web 层发邮件）
WEB_WEBHOOK_URL=
WEB_WEBHOOK_SECRET=
